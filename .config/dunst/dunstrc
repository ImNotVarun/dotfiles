# Dunst configuration - macOS style centered notifications
# Save this to ~/.config/dunst/dunstrc
[global]
    include = ~/.cache/wal/dunstrc

    # Display
    monitor = 0
    follow = none
    
    # Geometry - centered at top
    width = (400, 1200)
    height = 300
    origin = top-center
    offset = 0x25
    
    # Scale for HiDPI (adjust if needed)
    scale = 0
    
    # Progress bar
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    
    # Appearance
    notification_limit = 3
    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 24
    horizontal_padding = 24
    text_icon_padding = 24
    frame_width = 0
    frame_color = "#ffffff"
    gap_size = 8
    separator_color = frame
    sort = yes
    
    # Text
    font = SF Pro Display 11
    line_height = 6
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = center
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = no
    
    # Icons
    enable_recursive_icon_lookup = true
    icon_theme = Adwaita
    icon_position = top
    min_icon_size = 48
    max_icon_size = 64
    icon_path = /usr/share/icons/Adwaita/scalable/status/:/usr/share/icons/Adwaita/scalable/devices/
    
    # History
    sticky_history = yes
    history_length = 20
    
    # Misc
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 12
    ignore_dbusclose = false
    
    # Mouse
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

# macOS-style urgency levels
[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 3
    frame_color = "#89b4fa"

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 5
    frame_color = "#89b4fa"

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8"
    timeout = 0

# Custom rules for wallpaper notifications
[wallpaper]
    appname = "notify-send"
    summary = "*Wallpaper*"
    background = "#1e1e2edd"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 4
    corner_radius = 16
    icon_position = left